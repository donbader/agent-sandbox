FROM alpine:3.21
RUN apk add --no-cache ca-certificates wget
COPY gateway /usr/local/bin/gateway
COPY config.yaml /etc/gateway/config.yaml
COPY plugins.yaml /etc/gateway/plugins.yaml
COPY plugins/ /etc/gateway/plugins/
EXPOSE 8080
HEALTHCHECK --interval=5s --timeout=3s --retries=3 CMD wget --spider -q http://localhost:8080/health || exit 1
CMD ["gateway"]
