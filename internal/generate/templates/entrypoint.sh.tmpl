#!/bin/sh
set -e

# Configuration via environment (set by compose).
: "${AGENT_USER:=agent}"
: "${AGENT_HOME:=/home/agent}"

# Shared gateway routing (iptables DNAT, DNS, CA cert).
. /usr/local/bin/gateway-route.sh
{{- if .PreEntrypoint }}

# Plugin pre-entrypoint commands
{{ .PreEntrypoint }}
{{- end }}

# Ensure the agent user owns its home directory (root may have created files during setup).
chown -R "$AGENT_USER:$AGENT_USER" "$AGENT_HOME"

# Create workspace directory for agent sessions.
mkdir -p "{{ .CWD }}"
chown "$AGENT_USER:$AGENT_USER" "{{ .CWD }}"

# Drop privileges to the agent user for the actual process.
exec gosu "$AGENT_USER" "$@"
