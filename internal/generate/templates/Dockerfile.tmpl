FROM {{ .BaseImage }}
{{- range .PresetInstalls }}

RUN {{ . }}
{{- end }}
{{- if not .IsPreset }}

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates wget gosu iptables iproute2 iputils-ping \
    && rm -rf /var/lib/apt/lists/*
{{- end }}

RUN useradd -m -s /bin/bash agent
ENV HOME=/home/agent
WORKDIR /home/agent
{{- range .ExtraBuilds }}

{{ . }}
{{- end }}

COPY {{ .EntrypointPath }} /usr/local/bin/entrypoint.sh
COPY {{ .GatewayRoutePath }} /usr/local/bin/gateway-route.sh
RUN chmod +x /usr/local/bin/entrypoint.sh /usr/local/bin/gateway-route.sh
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
{{- if .CMD }}

CMD {{ .CMD }}
{{- end }}
